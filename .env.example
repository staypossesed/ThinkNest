# Режим разработки: без backend и Google (или npm run dev:local)
# DEV_MODE=true

BACKEND_API_URL=http://localhost:8787
OLLAMA_BASE_URL=http://localhost:11434/v1
# Таймаут на агента (мс). По умолчанию 90000 (90 сек)
OLLAMA_TIMEOUT_MS=90000
# SEQUENTIAL_AGENTS=false — параллельный запуск (быстрее, но может перегружать Ollama)

# Web Search (Use Web Data): нужен хотя бы один ключ для поиска в Google
# SERPER_API_KEY — бесплатно 2500 запросов/мес: https://serper.dev
# SERPAPI_KEY — альтернатива: https://serpapi.com
# SERPER_API_KEY=xxx
# SERPAPI_KEY=xxx
