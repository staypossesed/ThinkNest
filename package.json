{
  "name": "multi-agent-desktop",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:backend": "npm --prefix backend run dev",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:electron": "wait-on tcp:5173 dist/main/index.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:electron:local": "wait-on tcp:5173 dist/main/index.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 DEV_MODE=true electron .",
    "dev:local": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:electron:local\"",
    "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:electron\"",
    "build:renderer": "vite build --config vite.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "build:backend": "npm --prefix backend run build",
    "build": "npm run build:renderer && npm run build:main && npm run build:backend",
    "package": "npm run build && electron-builder",
    "test": "echo \"No tests configured\" && exit 0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.3.1",
    "duck-duck-scrape": "^2.2.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "supabase": "^2.76.15",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.local.multiagent",
    "productName": "Multi Agent Desktop",
    "directories": {
      "output": "dist/app"
    },
    "files": [
      "dist/main/**",
      "dist/renderer/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
