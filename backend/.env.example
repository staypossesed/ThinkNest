PORT=8787
APP_ORIGIN=http://localhost:5173
APP_JWT_SECRET=replace-with-long-random-secret

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# Stripe (optional — без них billing отключён)
# 1. Stripe Dashboard: Products -> Create "Pro" -> Add Price (monthly recurring)
# 2. Developers -> API keys: скопируй Secret key
# 3. Developers -> Webhooks: Add endpoint POST https://<your-backend>/webhooks/stripe
#    События: checkout.session.completed, customer.subscription.*, invoice.payment_failed
# 4. Customer Portal: включи в Stripe Dashboard (Billing -> Customer portal)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_SUCCESS_URL=http://localhost:5173/success
STRIPE_CANCEL_URL=http://localhost:5173/cancel
