PORT=8787
APP_ORIGIN=http://localhost:5173
APP_JWT_SECRET=replace-with-long-random-secret

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# Stripe (optional — billing disabled if missing)
# 1. API keys: Developers -> API keys -> Secret key
# 2. Price IDs: Product catalog -> click Pro Weekly/Monthly/Yearly -> copy Price ID (price_...)
# 3. Webhook: Developers -> Webhooks -> Add endpoint -> POST https://<your-backend>/webhooks/stripe
# 4. Customer Portal: Settings -> Billing -> Customer portal (enable)
# 5. Optional: Product catalog -> Coupons -> copy Coupon ID for yearly discount
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_WEEKLY=price_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_YEARLY=price_xxx
STRIPE_COUPON_1PLUS1=
STRIPE_SUCCESS_URL=http://localhost:5173
STRIPE_CANCEL_URL=http://localhost:5173

# Ollama (server-side AI — models run on server)
# Используется нативный /api/chat — быстрее чем /v1
OLLAMA_BASE_URL=http://localhost:11434/v1
# Таймаут на агента (мс). Для CPU: 90000. Для GPU: 45000
OLLAMA_TIMEOUT_MS=90000

# Web Search (optional — Serper 2500 free/month)
SERPER_API_KEY=
